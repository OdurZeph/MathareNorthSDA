# Server
PORT=5000
NODE_ENV=development
JWT_SECRET=your-secret-key-change-this-in-production

# MySQL
DATABASE_URL=mysql://root:password@localhost:3306/church_db
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=church_db

# Email (Gmail: use an App Password - https://myaccount.google.com/apppasswords)
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-16-char-app-password

# All form notifications are delivered here (default if unset)
EMAIL_TO=zephoduor14@gmail.com

# Optional SMTP overrides (defaults: smtp.gmail.com:465)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true

# Optional: extra CORS origins (comma-separated)
# ALLOWED_ORIGINS=https://your-domain.com

# Cloudflare Turnstile (optional - forms work without it)
# TURNSTILE_SECRET_KEY=

# Safaricom Daraja (M-Pesa)
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=

# PAYBILL (Tithes, Offering, Missions)
MPESA_PAYBILL=174379
MPESA_PAYBILL_PASSKEY=

# TILL (Building Fund)
MPESA_TILL=

MPESA_CALLBACK_URL=https://your-domain.com/api/mpesa/callback

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-email-app-password
EMAIL_FROM=no-reply@your-domain.com
BASE_URL=http://localhost:5000

# Backward-compatible legacy names still supported by the backend
CONSUMER_KEY=
CONSUMER_SECRET=
PASSKEY=
TILL_SHORTCODE=
PAYBILL_SHORTCODE=
CALLBACK_URL=
