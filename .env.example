# Server
PORT=5000
NODE_ENV=development
JWT_SECRET=your-secret-key-change-this-in-production

# MySQL
DATABASE_URL=mysql://root:password@localhost:3306/church_db
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=church_db

# Email (Gmail App Password — https://myaccount.google.com/apppasswords)
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-16-char-app-password

# All form notifications go here (default: zephoduor14@gmail.com)
EMAIL_TO=zephoduor14@gmail.com
PRAYER_RECEIVER_EMAIL=zephoduor14@gmail.com

# Optional SMTP overrides (defaults: smtp.gmail.com:465 secure)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true

# Legacy aliases still supported by newsletter service
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=465
# EMAIL_PASSWORD=same-as-EMAIL_PASS
# EMAIL_FROM=no-reply@your-domain.com

# Optional: extra CORS origins (comma-separated)
# ALLOWED_ORIGINS=https://your-domain.com

# Cloudflare Turnstile (optional - forms work without it)
# TURNSTILE_SECRET_KEY=

# Safaricom Daraja (M-Pesa)
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=your-consumer-key
MPESA_CONSUMER_SECRET=your-consumer-secret

# PAYBILL — used for: general, donation, church support, tithe, offering, missions
MPESA_PAYBILL=303030
MPESA_PAYBILL_ACCOUNT=2028923379
MPESA_PAYBILL_PASSKEY=your-paybill-passkey

# TILL — used for: building fund, construction
MPESA_TILL_NUMBER=183254

MPESA_CALLBACK_URL=https://your-domain.com/api/mpesa/callback

# Public site URL (used in subscription verification links)
BASE_URL=http://localhost:5000

# Backward-compatible legacy names still supported by the backend
CONSUMER_KEY=
CONSUMER_SECRET=
PASSKEY=
TILL_SHORTCODE=
PAYBILL_SHORTCODE=
CALLBACK_URL=
